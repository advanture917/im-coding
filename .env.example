FEISHU_ENABLED=true
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=replace_with_app_secret

# Optional Feishu webhook fields:
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_ENCRYPT_KEY=

# Bridge:
# IM_CODING_PORT=4399
# IM_CODING_BRIDGE_URL=http://127.0.0.1:4399
# IM_CODING_HOOK_TOKEN=
# IM_CODING_STORE_PATH=~/.im-coding/im-coding.db

# Codex:
IM_CODING_CODEX_DRIVER=app-server
# Other supported values: stub, cli
# IM_CODING_CODEX_SANDBOX=workspace-write
# IM_CODING_CODEX_APPROVAL=never
# CODEX_BIN=/Applications/Codex.app/Contents/Resources/codex

# Default project:
# IM_CODING_PROJECT_ID=im-coding
# IM_CODING_PROJECT_NAME=im-coding
# IM_CODING_PROJECT_ROOT=/absolute/path/to/project
# IM_CODING_PROJECT_TOOL=codex
# IM_CODING_PROJECT_STATUS=active

# Multiple projects can be configured as JSON:
# IM_CODING_PROJECTS_JSON=[{"id":"im-coding","name":"im-coding","rootPath":"/absolute/path","codingTool":"codex","status":"active"}]

# Comma-separated Feishu open_ids. Empty means allow all local-dev users.
# IM_CODING_ALLOWED_FEISHU_USERS=ou_xxx,ou_yyy
